<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".KeyMasterApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.KeyMaster"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Main activity: Compose UI for setup/management -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KeyMaster">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NIP-55 Signer Activity: handles nostrsigner: intents -->
        <activity
            android:name=".nip55.SignerActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nostrsigner" />
            </intent-filter>
        </activity>

        <!-- NIP-55 Account Picker: user selects which account to expose -->
        <activity
            android:name=".nip55.AccountPickerActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- NIP-55 Content Provider: background operations -->
        <provider
            android:name=".nip55.SignerContentProvider"
            android:authorities="club.dwdc.keymaster.SIGN_EVENT;club.dwdc.keymaster.NIP44_ENCRYPT;club.dwdc.keymaster.NIP44_DECRYPT"
            android:exported="true" />

        <!-- NIP-46 Remote Signer Service -->
        <service
            android:name=".nip46.Nip46Service"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
